# Database (SQLite for local dev)
DATABASE_URL="file:./prisma/dev.db"

# NextAuth (required for login to work)
NEXTAUTH_URL="http://localhost:3000"
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Optional: only these emails can sign in (comma-separated). Leave empty to allow any.
# ALLOWED_EMAILS="admin@gnbank.net,ops@gnbank.net"

# Email (magic link) – e.g. SMTP or use a service like Resend
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="noreply@yourdomain.com"
